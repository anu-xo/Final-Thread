{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:5173/"
      ],
      "numberOfRuns": 1,
      "startServerCommand": "npx serve dist -l 5173 -s",
      "startServerReadyPattern": "Accepting",
      "startServerReadyTimeout": 30000,
      "settings": {
        "throttlingMethod": "provided",
        "throttling": {
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }]
      }
    }
  }
}
