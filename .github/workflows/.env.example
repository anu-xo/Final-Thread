# Server
PORT=5000
NODE_ENV=development

# MongoDB (Docker local)
MONGODB_URI=mongodb://admin:password123@localhost:27017/threadverse?authSource=admin

# Redis (Docker local)
REDIS_URL=redis://localhost:6379

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# AI Keys — get from aistudio.google.com and console.groq.com
GEMINI_API_KEY=CHANGE_ME
GROQ_API_KEY=CHANGE_ME

# Email — get from sendgrid.com
SENDGRID_API_KEY=CHANGE_ME
FROM_EMAIL=noreply@threadverse.app

# Cloudinary — get from cloudinary.com
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
JWT_SECRET=88a6bdf0906f4debd6092a3b5cd2871a6c4f84f461fe2ecd32fc4fbfc1d33506b43eecd485a493809cefa7abbc32caea184d16e7200978a6eb02c8c77b4e74ef
JWT_REFRESH_SECRET=6635e25b5dcc4390a1488b1de60ab3c29bc0002316f1c41a0d32a50a84aaf4551bb2cbe09327bf8149f3972e8eae0228a0849300f5a8a53e4117232b8b24eb43
